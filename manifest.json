{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.3",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "permissions": ["favicon", "storage", "tabs"],
  "action": {
    "default_popup": "options.html"
  },
  "options_ui": {
